{
  "name": "category-api",
  "version": "1.0.0",
  "description": "Category management API with GraphQL, MongoDB, and Redis",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev -r tsconfig-paths/register --respawn --transpile-only src/index.ts",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "seed": "ts-node -r tsconfig-paths/register src/seeds/runner.ts",
    "test": "jest --runInBand --forceExit --detectOpenHandles",
    "test:coverage": "jest --runInBand --forceExit --coverage"
  },
  "dependencies": {
    "@apollo/server": "^5.5.0",
    "@as-integrations/express5": "^1.1.2",
    "cors": "^2.8.6",
    "dataloader": "^2.2.3",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.4.1",
    "graphql": "^16.13.2",
    "graphql-depth-limit": "^1.1.0",
    "graphql-query-complexity": "^1.1.0",
    "helmet": "^8.1.0",
    "http-errors": "^2.0.1",
    "ioredis": "^5.10.1",
    "mongoose": "^9.6.0",
    "morgan": "^1.10.1",
    "uuid": "^9.0.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/http-errors": "^2.0.5",
    "@types/morgan": "^1.9.10",
    "@types/node": "^22.19.17",
    "@types/uuid": "^9.0.1",
    "@types/graphql-depth-limit": "^1.1.4",
    "eslint": "^10.2.1",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "@types/jest": "^29.5.13",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.2",
    "mongodb-memory-server": "^10.1.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["<rootDir>/src/tests"],
    "testMatch": ["**/tests/**/*.test.ts"],
    "globalSetup": "<rootDir>/src/tests/helpers/globalSetup.ts",
    "globalTeardown": "<rootDir>/src/tests/helpers/globalTeardown.ts",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/tests/**",
      "!src/seeds/**",
      "!src/index.ts"
    ],
    "testTimeout": 30000,
    "openHandlesTimeout": 1000
  }
}
